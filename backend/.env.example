# ForeignEdge Backend Environment Variables
# Copy this file to .env and fill in your values

# Flask secret key (change this in production!)
SECRET_KEY=foreignedge-super-secret-key-change-in-production

# JWT secret key (change this in production!)
JWT_SECRET_KEY=foreignedge-jwt-secret-change-in-production

# Groq AI API Key (optional - mock fallback used if not set)
# Get your free key at: https://console.groq.com
GROQ_API_KEY= your_groq_api_key_here

# Flask environment
FLASK_ENV=development
FLASK_DEBUG=True
